GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Which provider to use for AI recommendations: "groq" or "deepseek"
AI_PROVIDER=groq

# Google PageSpeed Insights (optional; works without a key at low volume)
GOOGLE_PSI_API_KEY=
USE_PSI=true
PSI_STRATEGY=mobile

# Branding (defaults to AI Commandos / agent Atlas — see src/config.js)
BRAND_NAME=AI Commandos
BRAND_COLOR=#0abe9f
BRAND_COLOR2=#0a0c11
BRAND_ACCENT=#ed4514
BRAND_AGENT=Atlas
BRAND_TAGLINE=Agents IA d’élite — audit propulsé par Atlas
# Default report language: "fr" or "en" (also switchable per-request via the UI toggle)
REPORT_LANG=fr
BRAND_LOGO_URL=
BRAND_WEBSITE=ai-commandos.com
BRAND_EMAIL=
BRAND_PHONE=

PORT=3000
