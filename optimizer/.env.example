GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat

# Which provider to use for AI recommendations: "groq" or "deepseek"
AI_PROVIDER=groq

# Google PageSpeed Insights (optional; works without a key at low volume)
GOOGLE_PSI_API_KEY=
USE_PSI=true
PSI_STRATEGY=mobile

# White-label branding (optional)
BRAND_NAME=
BRAND_COLOR=#1d4ed8
BRAND_COLOR2=#0f172a
BRAND_LOGO_URL=
BRAND_WEBSITE=
BRAND_EMAIL=
BRAND_PHONE=

PORT=3000
